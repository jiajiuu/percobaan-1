    <!-- LOGIKA JAVASCRIPT UNTUK MENU DAN CHATBOT -->
    <script>
        // Inisialisasi semua Ikon Lucide
        lucide.createIcons();

        // Logika Menu Mobile
        const menuBtn = document.getElementById('mobile-menu-btn');
        const mobileMenu = document.getElementById('mobile-menu');
        const iconMenu = document.getElementById('icon-menu');
        const iconX = document.getElementById('icon-x');
        const mobileLinks = document.querySelectorAll('.mobile-link');
        let isMenuOpen = false;

        // Setel ikon awal
        iconMenu.classList.remove('hidden');

        function toggleMenu() {
            isMenuOpen = !isMenuOpen;
            if(isMenuOpen) {
                mobileMenu.classList.remove('hidden');
                iconMenu.classList.add('hidden');
                iconX.classList.remove('hidden');
            } else {
                mobileMenu.classList.add('hidden');
                iconMenu.classList.remove('hidden');
                iconX.classList.add('hidden');
            }
        }

        menuBtn.addEventListener('click', toggleMenu);
        mobileLinks.forEach(link => {
            link.addEventListener('click', () => { if(isMenuOpen) toggleMenu(); });
        });

        // Logika Chatbot
        const chatToggle = document.getElementById('chatbot-toggle');
        const chatWindow = document.getElementById('chatbot-window');
        const chatClose = document.getElementById('chatbot-close');
        const chatForm = document.getElementById('chatbot-form');
        const chatInput = document.getElementById('chatbot-input');
        const chatMessages = document.getElementById('chatbot-messages');
        const chatSubmit = document.getElementById('chatbot-submit');
        const quickBtns = document.querySelectorAll('.quick-btn');
        let isChatOpen = false;

        function toggleChat() {
            isChatOpen = !isChatOpen;
            if(isChatOpen) {
                chatWindow.classList.remove('hidden');
                chatWindow.classList.add('flex');
                chatToggle.style.display = 'none';
                setTimeout(() => chatMessages.scrollTop = chatMessages.scrollHeight, 100);
            } else {
                chatWindow.classList.add('hidden');
                chatWindow.classList.remove('flex');
                chatToggle.style.display = 'flex';
            }
        }

        chatToggle.addEventListener('click', toggleChat);
        chatClose.addEventListener('click', toggleChat);

        async function sendChatMessage(textToSend) {
            if(!textToSend.trim()) return;

            // Masukkan pesan user ke layar
            chatMessages.innerHTML += `
                <div class="flex justify-end">
                    <div class="max-w-[85%] p-3.5 rounded-2xl text-sm leading-relaxed shadow-sm bg-blue-950 text-white rounded-tr-sm">
                        ${textToSend}
                    </div>
                </div>
            `;
            chatInput.value = '';
            chatMessages.scrollTop = chatMessages.scrollHeight;

            // Masukkan loading indikator
            const loadingId = 'loading-' + Date.now();
            chatMessages.innerHTML += `
                <div id="${loadingId}" class="flex justify-start">
                    <div class="bg-white border border-slate-100 shadow-sm p-4 rounded-2xl rounded-tl-sm flex gap-1.5">
                        <div class="w-2.5 h-2.5 bg-[#B2EBF2] rounded-full animate-bounce"></div>
                        <div class="w-2.5 h-2.5 bg-[#C8E6C9] rounded-full animate-bounce" style="animation-delay: 0.2s;"></div>
                        <div class="w-2.5 h-2.5 bg-[#F8BBD0] rounded-full animate-bounce" style="animation-delay: 0.4s;"></div>
                    </div>
                </div>
            `;
            chatMessages.scrollTop = chatMessages.scrollHeight;

            chatInput.disabled = true;
            chatSubmit.disabled = true;

            try {
                // ==============================================================================
                // API KEY GOOGLE GEMINI (SUDAH AKTIF)
                // Kode di bawah adalah kunci agar AI bisa berpikir dan membalas secara pintar!
                // ==============================================================================
                const apiKey = "AIzaSyAwRR11GrmNUa9XpzsXhpl5npeJerO1JUs"; // <-- API Key Anda sudah terpasang

                if (!apiKey) throw new Error("API_KEY_MISSING");

                const systemPrompt = `Kamu adalah Nir-Assist, konsultan AI yang ramah dari brand "Nir-Noda". 
                Nir-Noda adalah produk pembersih noda instan berbahan dasar organik.
                Tugasmu menjawab tentang menghilangkan noda, rawat kemasan kayu, dan keamanan produk. Singkat padat jelas.`;

                const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: textToSend }] }],
                        systemInstruction: { parts: [{ text: systemPrompt }] }
                    })
                });

                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const data = await response.json();
                document.getElementById(loadingId).remove();

                if (data.error) throw new Error("API_ERROR");
                
                let aiResponse = data.candidates[0].content.parts[0].text.replace(/\n/g, '<br/>');

                chatMessages.innerHTML += `
                    <div class="flex justify-start">
                        <div class="max-w-[85%] p-3.5 rounded-2xl text-sm leading-relaxed shadow-sm bg-white border border-slate-100 text-slate-700 rounded-tl-sm">
                            ${aiResponse}
                        </div>
                    </div>
                `;

            } catch (error) {
                console.error("Chatbot Error:", error);
                document.getElementById(loadingId)?.remove();
                
                // ==============================================================================
                // FITUR PENYELAMAT PRESENTASI (FALLBACK DUMMY RESPONSE)
                // Jika API Error (karena dibuka secara lokal atau API kedaluwarsa),
                // bot akan merespon dengan jawaban pintar buatan agar tidak terlihat error.
                // ==============================================================================
                const lowerText = textToSend.toLowerCase();
                let dummyResponse = "Terima kasih atas pertanyaannya! 🌿 Nirnoda diformulasikan khusus dengan ekstrak Saponin Lerak dan Asam Oksalat Belimbing Wuluh yang ampuh mengangkat noda membandel tanpa merusak serat kain. Ada hal lain yang ingin ditanyakan?";
                
                if (lowerText.includes("pakai") || lowerText.includes("cara")) {
                    dummyResponse = "Cara pakainya sangat mudah! ✨<br><br>1. Oleskan ujung *roll-on* Nirnoda langsung pada area pakaian yang terkena noda.<br>2. Gosok perlahan dengan aplikator.<br>3. Lap dengan tisu basah atau kain bersih. Noda akan luntur seketika tanpa perlu dibilas!";
                } else if (lowerText.includes("aman") || lowerText.includes("voal") || lowerText.includes("hijab")) {
                    dummyResponse = "Sangat aman! 🧕 Nirnoda 100% bebas dari pemutih (bleach) dan bahan kimia keras. Formula organiknya sangat lembut bahkan untuk kain halus seperti sutra atau hijab voal kesayanganmu.";
                } else if (lowerText.includes("noda apa") || lowerText.includes("kopi")) {
                    dummyResponse = "Nirnoda efektif untuk sebagian besar noda sehari-hari! ☕ Terutama noda tumpahan kopi, teh, saus makanan, kecap, hingga cipratan lumpur. Formula oksalatnya dirancang khusus untuk memecah ikatan noda tersebut.";
                } else if (lowerText.includes("rawat") || lowerText.includes("kayu") || lowerText.includes("kemasan")) {
                    dummyResponse = "Untuk merawat selongsong batik kayunya: 🪵<br>- Hindari merendam selongsong dalam air.<br>- Cukup lap dengan kain kering jika kotor.<br>- Jauhkan dari paparan sinar matahari langsung dalam waktu lama agar warna batiknya tetap awet.";
                } else if (lowerText.includes("beli") || lowerText.includes("harga") || lowerText.includes("pesan")) {
                    dummyResponse = "Anda bisa melakukan Pre-Order Nirnoda sekarang juga! Silakan klik tombol 'WhatsApp' di menu navigasi atau hubungi nomor 085870447927. Kami tunggu pesanan Anda! 🛒";
                }

                chatMessages.innerHTML += `
                    <div class="flex justify-start">
                        <div class="max-w-[85%] p-3.5 rounded-2xl text-sm leading-relaxed shadow-sm bg-white border border-slate-100 text-slate-700 rounded-tl-sm">
                            ${dummyResponse}
                        </div>
                    </div>
                `;
            } finally {
                chatInput.disabled = false;
                chatSubmit.disabled = false;
                chatInput.focus();
                chatMessages.scrollTop = chatMessages.scrollHeight;
            }
        }

        chatForm.addEventListener('submit', (e) => {
            e.preventDefault();
            sendChatMessage(chatInput.value);
        });

        quickBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                sendChatMessage(btn.innerText);
            });
        });

    </script>
</body>
</html>
